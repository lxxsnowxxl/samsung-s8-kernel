#!/bin/bash
# LIGHTNING-KERNEL-BUILD

# Variables
DIR="$(pwd)"


PARENT_DIR="$(pwd)"

echo "Cloning dependencies"
git clone --depth=1 --branch main https://github.com/lxxsnowxxl/samsung-s8-kernel kernel
cd kernel 
git clone --depth=1 https://github.com/LineageOS/android_prebuilts_gcc_linux-x86_aarch64_aarch64-linux-android-4.9 aarch64-linux-android-4.9
git clone --depth=1 https://github.com/prorooter007/android_prebuilts_clang_host_linux-x86_clang-6877366 clang-r383902
git clone --depth=1 https://github.com/osm0sis/AnyKernel3 AnyKernel3
echo "Done"
KERNEL_DIR=$(pwd)
OUT_DIR="$(pwd)/out"
REPACK_DIR="${KERNEL_DIR}/AnyKernel3"
IMAGE="${KERNEL_DIR}/arch/arm64/boot/Image"
BRANCH="$(git rev-parse --abbrev-ref HEAD)"

export PLATFORM_VERSION=9
export ANDROID_MAJOR_VERSION=p
export ARCH=arm64
export CROSS_COMPILE="$(pwd)/aarch64-linux-android-4.9/bin/aarch64-linux-android-"
export LINUX_GCC_CROSS_COMPILE_PREBUILTS_BIN="$(pwd)/aarch64-linux-android-4.9/bin"
export CLANG_TRIPLE="$(pwd)/clang-r383902/bin/aarch64-linux-gnu-"
export CLANG_PREBUILT_BIN="$(pwd)/clang-r383902/bin"
export PATH=$PATH:$CLANG_PREBUILT_BIN:$LINUX_GCC_CROSS_COMPILE_PREBUILTS_BIN

# Color
ON_BLUE=`echo -e "\033[44m"`	# On Blue
BRED=`echo -e "\033[1;31m"`	# Bold Red
BBLUE=`echo -e "\033[1;34m"`	# Bold Blue
BGREEN=`echo -e "\033[1;32m"`	# Bold Green
UNDER_LINE=`echo -e "\e[4m"`	# Text Under Line
STD=`echo -e "\033[0m"`		# Text Clear
 
build_kernel() {
    echo "${BGREEN}***** Compiling kernel *****${STD}"

    mkdir -p "$OUT_DIR"

    make -j"$(nproc)" exynos8895-dream2lte_defconfig
    make -j"$(nproc)"

    # Guardar kernel compilado
    [ -f arch/arm64/boot/Image.gz ] && cp arch/arm64/boot/Image.gz "$OUT_DIR/"
    [ -f arch/arm64/boot/Image ] && cp arch/arm64/boot/Image "$OUT_DIR/"

    if [ -f arch/arm64/boot/Image ]; then
        echo "${BGREEN}***** Ready to Roar *****${STD}"

        cd "$REPACK_DIR"
        git reset --hard

        # Kernel
        cp "$IMAGE" zImage

        # Copiar dtb si existe
        if [ -f "$KERNEL_DIR/arch/arm64/boot/dtb.img" ]; then
            cp "$KERNEL_DIR/arch/arm64/boot/dtb.img" .
        fi

        # Copiar dtbo solo si existe
        if [ -f "$OUT_DIR/dtbo.img" ]; then
            cp "$OUT_DIR/dtbo.img" .
        fi

        # Personalizar AnyKernel3
        sed -i 's/ExampleKernel by osm0sis/Galaxy S8 Exynos8895 Kernel/g' anykernel.sh
        sed -i 's/=maguro/=dream2lte/g' anykernel.sh
        sed -i 's/=toroplus/=/g' anykernel.sh
        sed -i 's/=toro/=/g' anykernel.sh
        sed -i 's/=tuna/=/g' anykernel.sh

        zip -r9 GalaxyS8-Exynos8895-Kernel.zip . \
            -x .git README.md "*placeholder"

        curl --data-binary @GalaxyS8-Exynos8895-Kernel.zip \
            https://bashupload.com/$REPACK_DIR/exynos2100-r9sxxx_kernel_.zip
    fi
}

build_kernel